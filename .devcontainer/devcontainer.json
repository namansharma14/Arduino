{
  "name": "Crown Currency — Competitor Intel",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "postCreateCommand": "cd competitor-intel && npm install && npm run seed",
  "postAttachCommand": "cd competitor-intel && (curl -sf http://localhost:4000/api/meta >/dev/null 2>&1 || npm start)",
  "forwardPorts": [4000],
  "portsAttributes": {
    "4000": {
      "label": "Competitor Intel Dashboard",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint"]
    }
  }
}
